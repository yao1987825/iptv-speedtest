# ==================== 数据目录配置 ====================

# 数据目录（根据不同设备修改）
# ImmortalWrt (ARM): /mnt/mmcblk2p4/docker/iptv-speedtest/data
# x86 服务器: /docker/iptv-speedtest/data
# 群晖 NAS: /volume1/docker/iptv-speedtest/data
DATA_DIR=/mnt/mmcblk2p4/docker/iptv-speedtest/data

# 脚本目录
SCRIPTS_DIR=./scripts

# Nginx 配置目录
NGINX_CONFIG=./nginx

# ==================== 服务配置 ====================

# HTTP 服务端口
HTTP_PORT=5353

# ==================== iptv_fetcher 配置 ====================

# 直播源获取间隔（秒），默认 1 小时
FETCH_INTERVAL=3600

# 直播源 URL
SOURCE_URL=https://gh-proxy.com/https://raw.githubusercontent.com/yaojiwei520/IPTV/refs/heads/main/iptv.m3u

# ==================== iptv_speedtest 配置 ====================

# 测速间隔（秒），默认 3 分钟
TEST_INTERVAL=180

# 单个频道超时时间（秒）
TEST_TIMEOUT=5
